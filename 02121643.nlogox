<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[;; ========================================
;; LLM-Augmented Collective Decision Model
;; FINAL VERSION - Fully Reviewed
;; ========================================
;;
;; DESIGN DECISIONS:
;; 1. AI-vote-share (0-0.5): relative voting power, comparable across N
;; 2. Hybrid-voter normative influence: only affects agents WITHOUT access
;; 3. SignalQuality: [0.5, 0.7] for realistic heterogeneity
;; 4. Social influence weights: 0.3 (info) / 0.4 (leader) / 0.2 (AI normative)
;;    - Based on stylized social psychology literature
;;    - Informational < Normative authority < Leader authority
;; 5. Trust update: negativity bias (error penalty > success reward)
;; 6. Voting rule: simple majority, tie breaks to 0
;;
;; AUTHORITY REGIMES:
;;   no-ai: pure human decision-making (baseline)
;;   advisor: AI influences beliefs via trust, NO voting power
;;   pure-voter: AI has voting power ONLY, NO belief influence
;;   hybrid-voter: AI has voting power AND normative influence
;;
;; INFORMATION STRUCTURE:
;;   centralized: only leader accesses AI (if applicable)
;;   distributed: coverage% of agents access AI (if applicable)
;;
;; ========================================

globals [
  truth                      ;; Ground truth (0 or 1)
  r                          ;; AI recommendation (0 or 1)
  correctCount               ;; Correct group decisions
  wrongCount                 ;; Wrong group decisions
  highConsensusWrongCount    ;; High-consensus (>66.7%) wrong decisions
  aiDecisiveCount            ;; Times AI vote changed outcome
  roundCount                 ;; Current round
  totalBeliefVariance        ;; Cumulative belief variance
  totalVoteVariance          ;; Cumulative pre-social vote variance
]

turtles-own [
  preSocialBelief            ;; Belief before social influence
  signalQuality              ;; P(correct private signal) in [0.5, 0.7]
  trust                      ;; Trust in AI, bounded [0,1]
  trustInstantaneous         ;; Unbounded trust (tracks miscalibration)
  conform                    ;; Conformity propensity [0,1]
  confidence                 ;; Confidence in own judgment [0,1]
  belief                     ;; Final belief [0,1]
  vote                       ;; Binary vote (0 or 1)
  hasAccess                  ;; Whether agent accesses AI this round
  isLeader                   ;; Whether agent is the leader
  trustHistory               ;; [[round, trust-before, trust-after, instantaneous], ...]
  wasOutvoted                ;; Whether outvoted by AI this round
  votedCorrectly             ;; Whether vote matched truth (for confidence calibration)
]

;; ========================================
;; SETUP
;; ========================================
to setup
  clear-all
  
  ;; Validate parameters
  if not validate-parameters [ 
    user-message "Invalid parameters! Check settings."
    stop 
  ]
  
  random-seed new-seed
  
  ;; Initialize globals
  set correctCount 0
  set wrongCount 0
  set highConsensusWrongCount 0
  set aiDecisiveCount 0
  set roundCount 0
  set totalBeliefVariance 0
  set totalVoteVariance 0
  
  ;; Create agents
  create-turtles N [
    set shape "person"
    set color blue
    setxy random-xcor random-ycor
    
    ;; Initialize trust (can be miscalibrated relative to A)
    set trust random-normal meanTrust sdTrust
    if trust < 0 [set trust 0]
    if trust > 1 [set trust 1]
    set trustInstantaneous trust
    set trustHistory []
    
    ;; Initialize conformity
    set conform random-normal meanConform sdConform
    if conform < 0 [set conform 0]
    if conform > 1 [set conform 1]
    
    ;; Initialize competence: [0.5, 0.7] = slightly better than chance
    set signalQuality 0.5 + random-float 0.2
    set confidence signalQuality
    
    ;; Initialize state
    set belief random-float 1.0
    set vote 0
    set hasAccess false
    set isLeader false
    set wasOutvoted false
    set votedCorrectly false
  ]
  
  ;; Designate leader (turtle 0)
  if centralised? [
    ask turtle 0 [
      set isLeader true
      set color red
      set size 1.5
    ]
  ]
  
  reset-ticks
end

;; ========================================
;; PARAMETER VALIDATION
;; ========================================
to-report validate-parameters
  ;; Check basic constraints
  if N < 3 [ 
    print "Error: N must be at least 3"
    report false 
  ]
  
  if AI-vote-share < 0 or AI-vote-share > 0.5 [
    print "Error: AI-vote-share must be in [0, 0.5]"
    report false
  ]
  
  if A < 0.5 or A > 1 [
    print "Error: A (AI accuracy) must be in [0.5, 1]"
    report false
  ]
  
  if coverage < 0 or coverage > 1 [
    print "Error: coverage must be in [0, 1]"
    report false
  ]
  
  ;; Check regime-specific constraints
  if authority-regime = "pure-voter" and AI-vote-share = 0 [
    print "Warning: pure-voter with AI-vote-share=0 is equivalent to no-ai"
  ]
  
  if authority-regime = "no-ai" and AI-vote-share > 0 [
    print "Warning: no-ai regime ignores AI-vote-share"
  ]
  
  report true
end

;; ========================================
;; MAIN LOOP
;; ========================================
to go
  if roundCount >= rounds [ stop ]
  run-round
  set roundCount roundCount + 1
  tick
end

;; ========================================
;; SINGLE ROUND
;; ========================================
to run-round
  ;; Step 1: Ground truth
  set truth random 2
  
  ;; Step 2: AI recommendation (if applicable)
  if authority-regime != "no-ai" [
    ifelse random-float 1.0 < A
      [ set r truth ]
      [ set r (1 - truth) ]
  ]
  
  ;; Step 3: Access assignment
  assign-access
  
  ;; Step 4-5: Belief formation
  update-beliefs
  
  ;; Step 6: Collective decision
  let group-decision make-group-decision
  
  ;; Step 7: Record outcomes
  record-outcomes group-decision
  
  ;; Step 8: Update trust
  update-trust group-decision
end

;; ========================================
;; ACCESS ASSIGNMENT
;; ========================================
to assign-access
  ask turtles [
    ;; No AI: no access
    if authority-regime = "no-ai" [
      set hasAccess false
      stop
    ]
    
    ;; Pure-voter: no human accesses AI (black box voter)
    if authority-regime = "pure-voter" [
      set hasAccess false
      stop
    ]
    
    ;; Advisor or Hybrid-voter: depends on information structure
    if authority-regime = "advisor" or authority-regime = "hybrid-voter" [
      ifelse centralised? [
        set hasAccess isLeader
      ][
        set hasAccess (random-float 1.0 < coverage)
      ]
    ]
  ]
end

;; ========================================
;; BELIEF UPDATE
;; ========================================
to update-beliefs
  ;; (1) Private signal + AI fusion
  ask turtles [
    ;; Private signal
    let private-signal ifelse-value (random-float 1.0 < signalQuality) 
      [truth] [1 - truth]
    set belief private-signal
    
    ;; AI fusion (only for advisor/hybrid with access)
    if hasAccess and authority-regime != "no-ai" and authority-regime != "pure-voter" [
      set belief (trust * r) + ((1 - trust) * belief)
    ]
    
    set preSocialBelief belief
  ]
  
  ;; Record pre-social variance (conflict burden)
  set totalVoteVariance totalVoteVariance + variance [preSocialBelief] of turtles
  
  ;; (2) Informational influence: peer averaging
  ;; Weight: 0.3 (Deutsch & Gerard 1955 - informational social influence)
  let mean-group-belief mean [belief] of turtles
  ask turtles [
    set belief belief + (0.3 * conform * (mean-group-belief - belief))
  ]
  
  ;; (3) Normative influence: leader authority
  ;; Weight: 0.4 (stronger than peer influence - Milgram authority effect)
  if centralised? [
    let leader-belief [belief] of turtle 0
    ask turtles with [not isLeader] [
      set belief belief + (0.4 * conform * (leader-belief - belief))
    ]
  ]
  
  ;; (4) Normative influence: AI as voter (ONLY hybrid-voter)
  ;; Weight: 0.2 (weaker than human authority - algorithm appreciation/aversion)
  ;; CRITICAL: Only affects agents WITHOUT access (to avoid double-counting)
  if authority-regime = "hybrid-voter" [
    ask turtles with [not hasAccess] [
      set belief belief + (0.2 * conform * (r - belief))
    ]
  ]
  
  ;; (5) Confidence filter + vote
  ask turtles [
    ;; High confidence → rely on pre-social belief
    ;; Low confidence → accept social influence
    set belief (confidence * preSocialBelief) + ((1 - confidence) * belief)
    set vote ifelse-value (belief >= 0.5) [1] [0]
  ]
end

;; ========================================
;; COLLECTIVE DECISION
;; ========================================
to-report make-group-decision
  ;; Human-only decision (for comparison)
  let human-decision ifelse-value 
    (count turtles with [vote = 1] > count turtles with [vote = 0])
    [1] [0]
  
  ;; No AI or Advisor: no AI voting power
  if authority-regime = "no-ai" or authority-regime = "advisor" [
    report human-decision
  ]
  
  ;; Pure-voter or Hybrid-voter: AI contributes weighted vote
  if authority-regime = "pure-voter" or authority-regime = "hybrid-voter" [
    let ai-weight effective-wAI
    let total-pro-1 (count turtles with [vote = 1]) + (ifelse-value (r = 1) [ai-weight] [0])
    let total-pro-0 (count turtles with [vote = 0]) + (ifelse-value (r = 0) [ai-weight] [0])
    let final-decision ifelse-value (total-pro-1 > total-pro-0) [1] [0]
    
    ;; Track if AI was decisive
    if final-decision != human-decision [
      set aiDecisiveCount aiDecisiveCount + 1
    ]
    
    report final-decision
  ]
  
  report 0  ;; Fallback
end

;; Convert AI-vote-share to absolute weight
;; Formula: wAI = N × share / (1 - share)
to-report effective-wAI
  if AI-vote-share = 0 [ report 0 ]
  if AI-vote-share >= 1 [ report 0 ]
  report N * AI-vote-share / (1 - AI-vote-share)
end

;; ========================================
;; RECORD OUTCOMES
;; ========================================
to record-outcomes [group-decision]
  ;; Track correctness
  ask turtles [
    set votedCorrectly (vote = truth)
  ]
  
  ;; Group accuracy
  ifelse group-decision = truth [
    set correctCount correctCount + 1
  ][
    set wrongCount wrongCount + 1
    
    ;; Cascade detection: >66.7% agreement on wrong answer
    let agreement ifelse-value (group-decision = 1)
      [count turtles with [vote = 1] / N]
      [count turtles with [vote = 0] / N]
    
    if agreement > 0.667 [
      set highConsensusWrongCount highConsensusWrongCount + 1
    ]
  ]
  
  ;; Polarization
  set totalBeliefVariance totalBeliefVariance + variance [belief] of turtles
end

;; ========================================
;; TRUST UPDATE
;; ========================================
to update-trust [group-decision]
  ask turtles with [hasAccess] [
    let trust-before trustInstantaneous
    let trust-delta 0
    
    ;; (1) AI correctness feedback (negativity bias)
    ifelse r = truth
      [ set trust-delta trust-delta + 0.05 ]
      [ set trust-delta trust-delta - 0.10 ]
    
    ;; (2) Outvoted effect (only in voter regimes)
    if authority-regime = "pure-voter" or authority-regime = "hybrid-voter" [
      let human-decision ifelse-value 
        (count turtles with [vote = 1] > count turtles with [vote = 0])
        [1] [0]
      
      let agent-preference ifelse-value (preSocialBelief >= 0.5) [1] [0]
      
      ;; AI vote was decisive
      if human-decision != group-decision [
        if agent-preference = human-decision [
          set wasOutvoted true
          
          ifelse group-decision = truth [
            ;; AI outvote led to correct decision
            set trust-delta trust-delta + 0.02
          ][
            ;; AI outvote led to wrong decision (sharp penalty)
            set trust-delta trust-delta - 0.15
          ]
        ]
      ]
    ]
    
    ;; Apply update
    set trustInstantaneous trustInstantaneous + trust-delta
    set trust trustInstantaneous
    if trust < 0 [set trust 0]
    if trust > 1 [set trust 1]
    
    ;; Record history
    set trustHistory lput (list roundCount trust-before trust trustInstantaneous) trustHistory
  ]
  
  ask turtles [ set wasOutvoted false ]
end

;; ========================================
;; PRIMARY REPORTERS
;; ========================================
to-report accuracy
  if roundCount = 0 [ report 0 ]
  report correctCount / roundCount
end

to-report cascade-rate
  if wrongCount = 0 [ report 0 ]
  report highConsensusWrongCount / wrongCount
end

to-report false-convergence
  if roundCount = 0 [ report 0 ]
  report highConsensusWrongCount / roundCount
end

to-report polarisation
  if roundCount = 0 [ report 0 ]
  report totalBeliefVariance / roundCount
end

;; ========================================
;; SECONDARY REPORTERS (CORRECTED)
;; ========================================

;; Overconfidence rate: high confidence but voted wrong
to-report confidence-calibration
  let overconfident count turtles with [confidence > 0.65 and not votedCorrectly]
  report overconfident / N
end

;; Leader dominance (centralized only)
to-report influence-inequality
  if not centralised? [ report 0 ]
  if roundCount = 0 [ report 0 ]
  
  let leader-vote [vote] of turtle 0
  let agreement count turtles with [vote = leader-vote and not isLeader]
  report agreement / (N - 1)
end

;; Pre-social disagreement level
to-report conflict-burden
  if roundCount = 0 [ report 0 ]
  report totalVoteVariance / roundCount
end

;; How often AI vote was decisive
to-report ai-decisive-rate
  if roundCount = 0 [ report 0 ]
  if authority-regime = "no-ai" or authority-regime = "advisor" [ report 0 ]
  report aiDecisiveCount / roundCount
end

;; ========================================
;; TRUST REPORTERS
;; ========================================
to-report mean-trust
  report mean [trust] of turtles
end

to-report mean-trust-instantaneous
  report mean [trustInstantaneous] of turtles
end

to-report trust-drift
  report mean [abs (trustInstantaneous - trust)] of turtles
end

to-report trust-miscalibration
  if authority-regime = "no-ai" [ report 0 ]
  report abs (mean [trust] of turtles - A)
end

to-report trust-bias
  if authority-regime = "no-ai" [ report 0 ]
  report mean [trust] of turtles - A
end

;; ========================================
;; DESCRIPTIVE REPORTERS
;; ========================================
to-report access-rate
  report count turtles with [hasAccess] / N
end

to-report mean-conformity
  report mean [conform] of turtles
end

to-report regime-summary
  let info ifelse-value centralised? ["centralized"] ["distributed"]
  if authority-regime = "no-ai" [ report "no-ai (baseline)" ]
  if authority-regime = "pure-voter" [ report "pure-voter (no info structure)" ]
  report (word authority-regime " / " info)
end

;; ========================================
;; EXPORT
;; ========================================
to export-trust-trajectories
  let filename (word "trust-" authority-regime "-run" behaviorspace-run-number ".csv")
  
  if file-exists? filename [ file-delete filename ]
  file-open filename
  file-print "agent,round,trust_before,trust_after,trust_instantaneous"
  
  ask turtles with [length trustHistory > 0] [
    foreach trustHistory [ hist ->
      file-print (word who "," (item 0 hist) "," (item 1 hist) "," 
                       (item 2 hist) "," (item 3 hist))
    ]
  ]
  
  file-close
  print (word "Exported: " filename)
end]]></code>
  <widgets>
    <view x="368" wrappingAllowedX="true" y="10" frameRate="30.0" minPycor="-16" height="434" showTickCounter="true" patchSize="13.0" fontSize="10" wrappingAllowedY="true" width="434" tickCounterLabel="ticks" maxPycor="16" updateMode="0" maxPxcor="16" minPxcor="-16"></view>
    <slider x="40" step="0.1" y="40" max="1" width="250" display="coverage" height="50" min="0" direction="Horizontal" default="0.5" variable="coverage"></slider>
