    <slider x="40" step="0.05" y="170" max="0.95" width="250" display="A" height="50" min="0.5" direction="Horizontal" default="0.75" variable="A"></slider>
    <slider x="40" step="1" y="235" max="50" width="250" display="N" height="50" min="1" direction="Horizontal" default="10.0" variable="N"></slider>
    <slider x="40" step="50" y="300" max="500" width="250" display="rounds" height="50" min="50" direction="Horizontal" default="200.0" variable="rounds"></slider>
    <slider x="40" step="0.1" y="365" max="1" width="250" display="meanTrust" height="50" min="0" direction="Horizontal" default="0.6" variable="meanTrust"></slider>
    <slider x="40" step="0.05" y="430" max="0.3" width="250" display="sdTrust" height="50" min="0.05" direction="Horizontal" default="0.15" variable="sdTrust"></slider>
    <slider x="40" step="0.1" y="495" max="1" width="250" display="meanConform" height="50" min="0" direction="Horizontal" default="0.4" variable="meanConform"></slider>
    <slider x="40" step="0.05" y="560" max="0.3" width="250" display="sdConform" height="50" min="0.05" direction="Horizontal" default="0.15" variable="sdConform"></slider>
    <monitor x="850" precision="17" y="30" height="60" fontSize="11" width="100">regime-summary</monitor>
    <monitor x="850" precision="17" y="100" height="60" fontSize="11" width="100">accuracy</monitor>
    <monitor x="850" precision="17" y="170" height="60" fontSize="11" width="100">false-convergence</monitor>
    <monitor x="850" precision="17" y="240" height="60" fontSize="11" width="100">cascade-rate</monitor>
    <monitor x="850" precision="17" y="310" height="60" fontSize="11" width="100">polarisation</monitor>
    <monitor x="850" precision="17" y="380" height="60" fontSize="11" width="100">confidence-calibration</monitor>
    <monitor x="850" precision="17" y="450" height="60" fontSize="11" width="100">influence-inequality</monitor>
    <monitor x="850" precision="17" y="520" height="60" fontSize="11" width="100">conflict-burden</monitor>
    <monitor x="965" precision="17" y="30" height="60" fontSize="11" width="100">ai-decisive-rate</monitor>
    <monitor x="965" precision="17" y="100" height="60" fontSize="11" width="100">mean-trust</monitor>
    <monitor x="965" precision="17" y="170" height="60" fontSize="11" width="100">trust-miscalibration</monitor>
    <monitor x="965" precision="17" y="240" height="60" fontSize="11" width="100">trust-bias</monitor>
    <monitor x="965" precision="17" y="310" height="60" fontSize="11" width="100">access-rate</monitor>
    <chooser x="460" y="465" height="60" variable="authority-regime" current="3" width="250" display="authority-regime">
      <choice type="string" value="no-ai"></choice>
      <choice type="string" value="advisor"></choice>
      <choice type="string" value="pure-voter"></choice>
      <choice type="string" value="hybrid-voter"></choice>
    </chooser>
    <switch x="550" y="545" height="40" on="true" variable="Centralised?" width="100" display="Centralised?"></switch>
    <button x="740" y="480" height="40" disableUntilTicks="false" forever="false" kind="Observer" width="55">setup</button>
    <button x="725" y="535" height="40" disableUntilTicks="false" forever="true" kind="Observer" width="55">go</button>
  </widgets>
