  <experiments>
    <experiment name="Exp1-NoAI" repetitions="30" sequentialRunOrder="false" runMetricsEveryStep="false">
      <setup>setup</setup>
      <go>go</go>
      <exitCondition><![CDATA[ticks >= 200]]></exitCondition>
      <metrics>
        <metric>accuracy</metric>
        <metric>cascade-rate</metric>
        <metric>false-convergence</metric>
        <metric>polarisation</metric>
        <metric>confidence-calibration</metric>
        <metric>conflict-burden</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="authority-regime">
          <value value="&quot;no-ai&quot;"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="centralised?">
          <value value="false"></value>
        </enumeratedValueSet>
        <steppedValueSet variable="meanConform" first="0.2" step="0.1" last="0.6"></steppedValueSet>
        <enumeratedValueSet variable="N">
          <value value="5"></value>
          <value value="15"></value>
          <value value="25"></value>
          <value value="35"></value>
        </enumeratedValueSet>
        <enumeratedValueSet variable="sdConform">
          <value value="0.15"></value>
        </enumeratedValueSet>
      </constants>
    </experiment>
